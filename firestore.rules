// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: maskapai
// Document ID: auto-generated or custom id
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - hargaJual: number
//   - hargaBeli: number
//   - margin: number
//   - persen: number
//   - programDays: number
//   - tanggalKeberangkatan: string (ISO date)
//   - tanggalKepulangan: string (ISO date)
//   - originCityName: string
//   - destinationCityName: string
//   - namaVendor: string
//   - totalSeat: number (required)
//   - remainingSeat: number (required)
//
// Collection: vendor_services
// Document ID: auto-generated or custom id
// Fields:
//   - id: string (required)
//   - paketId: string (required)
//   - namaPaket: string (required)
//   - namaLayanan: string (required)
//   - vendor: string (required)
//   - tanggalKeberangkatan: string (ISO date)
//   - tanggalKepulangan: string (ISO date)
//   - reminderDPHMinus: number
//   - reminderPelunasanHMinus: number
//   - estimasiBiaya: number
//   - statusPembayaran: string (Belum Bayar, DP, Lunas)
//   - pic: string (required)
//   - catatan: string
//   - isManualDate: boolean
//   - manualPelunasanDate: string (ISO date)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "operationalumaroh@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidMaskapai(data) {
      return data.keys().hasAll(['id', 'name', 'tanggalKeberangkatan', 'tanggalKepulangan', 'totalSeat', 'remainingSeat']) &&
             data.id is string &&
             data.name is string && data.name.size() < 200 &&
             data.totalSeat is number && data.totalSeat >= 0 &&
             data.remainingSeat is number && data.remainingSeat >= 0 &&
             data.remainingSeat <= data.totalSeat;
    }

    function isValidVendorService(data) {
      return data.keys().hasAll(['id', 'paketId', 'namaPaket', 'namaLayanan', 'vendor', 'tanggalKeberangkatan', 'tanggalKepulangan', 'statusPembayaran', 'pic']) &&
             data.id is string &&
             data.paketId is string &&
             data.namaPaket is string && data.namaPaket.size() < 200 &&
             data.namaLayanan is string && data.namaLayanan.size() < 100 &&
             data.vendor is string && data.vendor.size() < 100 &&
             data.statusPembayaran in ['Belum Bayar', 'DP', 'Lunas'] &&
             data.pic is string && data.pic.size() < 100;
    }

    match /maskapai/{maskapaiId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidMaskapai(request.resource.data);
      allow delete: if isAdmin();
      allow update: if isAuthenticated() && 
        (isAdmin() || 
         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['remainingSeat']) &&
          request.resource.data.remainingSeat < resource.data.remainingSeat &&
          request.resource.data.remainingSeat >= 0));
    }

    match /vendor_services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidVendorService(request.resource.data);
    }

    match /tracker_paket/{paketId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tracker_jamaah/{jamaahId} {
      allow read, write: if isAuthenticated();
    }
    
    match /tracker_keberangkatan/{keberangkatanId} {
      allow read, write: if isAuthenticated();
    }

    match /tracking_group/{groupId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && 
                    !request.resource.data.keys().contains('role');
    }
  }
}
